{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":automergePr",
    ":automergeMinor",
    ":combinePatchMinorReleases",
    ":semanticCommits",
    ":disableDependencyDashboard",
    "schedule:weekly"
  ],
  "labels": [
    "dependencies"
  ],
  "timezone": "Europe/Warsaw",
  "minimumReleaseAge": "7 days",
  "rangeStrategy": "replace",
  "prConcurrentLimit": 5,
  "prCreation": "not-pending",
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "enabledManagers": [
    "poetry",
    "github-actions"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "enabled": true,
      "commitMessagePrefix": "ci:"
    },
    {
      "matchManagers": [
        "poetry"
      ],
      "groupName": "Python dependencies",
      "labels": [
        "python"
      ],
      "schedule": [
        "every weekend"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "labels": [
        "major update"
      ],
      "prPriority": 10,
      "automerge": false,
      "commitMessagePrefix": "feat!:"
    }
  ]
}